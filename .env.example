# Cloud Nexus — Environment template
# Copy to .env and set values. Never commit .env.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://cloudnexus:changeme@postgres:5432/cloudnexus
POSTGRES_USER=cloudnexus
POSTGRES_PASSWORD=changeme
POSTGRES_DB=cloudnexus

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# ---------------------------------------------------------------------------
# Application (API + Worker)
# ---------------------------------------------------------------------------
# Min 32 bytes; use hex (64 chars) or base64. Generate: openssl rand -hex 32
SECRET_KEY=generate-a-32-byte-hex-or-base64-secret-key-here
# 32 bytes for AES-256-GCM; hex (64 chars) or base64. Generate: openssl rand -hex 32
ENCRYPTION_KEY=generate-a-32-byte-hex-key-for-aes-256-gcm

# Break-glass admin (local account). Required for seed; change in production.
ADMIN_PASSWORD=changeme

# Demo mode: enables seed, may relax validations. Set false in production.
DEMO_MODE=false
# Set to 1 to run seed (create admin role, admin user, sample site/connector).
SEED_DB=0

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Frontend (Web)
# ---------------------------------------------------------------------------
# Base URL of the API as seen by the browser (e.g. https://nexus.example.com/api)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Optional: SSO / LDAP (Phase 2)
# ---------------------------------------------------------------------------
# OIDC_ISSUER_URL=
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=
# LDAP_URL=ldaps://dc.example.com
# LDAP_BASE_DN=DC=example,DC=com
# LDAP_BIND_DN=
# LDAP_BIND_PASSWORD=

# ---------------------------------------------------------------------------
# Optional: Reverse proxy
# ---------------------------------------------------------------------------
# TRUSTED_PROXY=1
