# Cloud Nexus — Environment template
# Copy to .env and set values. Never commit .env.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://cloudnexus:changeme@postgres:5432/cloudnexus
POSTGRES_USER=cloudnexus
POSTGRES_PASSWORD=changeme
POSTGRES_DB=cloudnexus

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# ---------------------------------------------------------------------------
# Application (API + Worker)
# ---------------------------------------------------------------------------
# Min 32 bytes; use hex (64 chars) or base64. Generate: openssl rand -hex 32
SECRET_KEY=generate-a-32-byte-hex-or-base64-secret-key-here
# 32 bytes for AES-256-GCM; hex (64 chars) or base64. Generate: openssl rand -hex 32
ENCRYPTION_KEY=generate-a-32-byte-hex-key-for-aes-256-gcm

# Break-glass admin (local account). Required for seed; change in production.
ADMIN_PASSWORD=changeme

# Demo mode: enables seed, may relax validations. Set false in production.
DEMO_MODE=false
# Set to 1 to run seed (create admin role, admin user, sample site/connector).
SEED_DB=0

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# JSON logs (stdout) for log aggregators
# LOG_JSON=false

# ---------------------------------------------------------------------------
# API hardening (production)
# ---------------------------------------------------------------------------
# Comma-separated browser origins for CORS. Empty = no CORS middleware (same-origin / server-side only).
# CORS_ORIGINS=https://nexus.example.com
# TRUSTED_PROXY=1
# Fail startup if SECRET_KEY/ENCRYPTION_KEY still contain insecure placeholders
# PRODUCTION_REFUSE_INSECURE_DEFAULTS=false
# Login rate limit (slowapi), e.g. 30/minute
# AUTH_LOGIN_RATE_LIMIT=30/minute

# ---------------------------------------------------------------------------
# Reports (CSV output on disk)
# ---------------------------------------------------------------------------
# REPORT_STORAGE_DIR=/data/reports

# ---------------------------------------------------------------------------
# Ops email (ops request "send")
# ---------------------------------------------------------------------------
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=
# SMTP_USE_TLS=true

# ---------------------------------------------------------------------------
# HAProxy push (SSH from API host)
# ---------------------------------------------------------------------------
# HAPROXY_SSH_HOST=
# HAPROXY_SSH_USER=
# HAPROXY_SSH_KEY_PATH=
# HAPROXY_REMOTE_CONFIG_PATH=

# ---------------------------------------------------------------------------
# Automation runner (internal API; shared secret)
# ---------------------------------------------------------------------------
# AUTOMATION_RUNNER_SECRET=

# ---------------------------------------------------------------------------
# Frontend (Web)
# ---------------------------------------------------------------------------
# API base as seen by the browser. Leave empty behind nginx (same origin, TLS 443).
# Local dev without nginx: http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Optional: SSO / LDAP (Phase 2)
# ---------------------------------------------------------------------------
# OIDC_ISSUER_URL=
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=
# LDAP_URL=ldaps://dc.example.com
# LDAP_BASE_DN=DC=example,DC=com
# LDAP_BIND_DN=
# LDAP_BIND_PASSWORD=
# Search filter; {username} is LDAP-escaped. Default (sAMAccountName={username})
# LDAP_USER_SEARCH_FILTER=(sAMAccountName={username})

# ---------------------------------------------------------------------------
# Optional: Reverse proxy
# ---------------------------------------------------------------------------
# TRUSTED_PROXY=1
